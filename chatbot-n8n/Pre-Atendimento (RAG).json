      "parameters": {
        "jsCode": "// Pega todas as mensagens encontradas pelo Supabase\nconst items = $input.all();\n\nif (items.length === 0) {\n  // Retorna vazio se não achar nada para não quebrar\n  return [{ json: { RelatoFinal: \"\", QuantidadeMensagens: 0 } }];\n}\n\n// Mapeia apenas o texto da mensagem\nconst mensagens = items.map(item => item.json.mensagem);\n\n// Junta com quebra de linha e traço\nconst relatoCompleto = mensagens.join(\"\\n- \");\n\n// LIMITADOR DE CARACTERES (Segurança)\n// Corta se passar de 4000 caracteres (aprox 1000 tokens)\nconst relatoSeguro = relatoCompleto.length > 4000 \n  ? relatoCompleto.substring(0, 4000) + \"\\n...[Texto truncado por excesso de tamanho]\" \n  : relatoCompleto;\n\nreturn [\n  {\n    json: {\n      RelatoFinal: \"- \" + relatoSeguro,\n      QuantidadeMensagens: mensagens.length\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
